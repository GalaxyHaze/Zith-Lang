--- src/wasm/playground.cpp
+++ src/wasm/playground.cpp
@@ -32,6 +32,38 @@
     return last_error.size();
 }
 
+extern "C" __attribute__((export_name("zith_compile_source")))
+int zith_compile_source(const char* ptr, int len, int mode, int opt_level, int emit_mask) {
+    last_error.clear();
+    auto* session = zithc_session_create_from_buffer("playground.zith", ptr, len);
+    if (!session) {
+        last_error = "failed to create session";
+        return 1;
+    }
+
+    zithc_session_set_mode(session, static_cast<uint8_t>(mode));
+    zithc_session_set_opt_level(session, static_cast<uint8_t>(opt_level));
+    zithc_session_set_emit_flags(session, emit_mask & 1, emit_mask & 2, emit_mask & 4, emit_mask & 8);
+
+    bool ok = zithc_run(session);
+
+    size_t count = zithc_diag_count(session);
+    for (size_t i = 0; i < count; ++i) {
+        zithc_diagnostic diag = zithc_diag_get(session, i);
+        std::string msg;
+        if (diag.severity == ZITHC_SEVERITY_ERROR) msg += "error";
+        else if (diag.severity == ZITHC_SEVERITY_WARNING) msg += "warning";
+        else if (diag.severity == ZITHC_SEVERITY_NOTE) msg += "note";
+        msg += ": ";
+        msg += diag.message;
+        msg += "\n";
+        host_write(2, msg.data(), msg.size());
+    }
+
+    zithc_session_destroy(session);
+    return ok ? 0 : 1;
+}
+
